generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== TENANCY ====================
// Every other model below is scoped to a Company via a plain `companyId`
// scalar column (no Prisma-level relation object - these are enforced via a
// real FK + ON DELETE CASCADE at the SQL level in the migration, and via the
// tenant-scoping Prisma Client Extension in src/lib/prisma.ts at the
// application level; declaring 53 relation fields here would be pure
// boilerplate for data we only ever filter by, never traverse into from a
// child record).

model Company {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("active") // active | suspended
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== SETTINGS ====================

model Settings {
  companyId                    String   @id
  businessName                 String   @default("My Business")
  businessDesc                 String   @default("")
  welcomeMessage               String   @default("Hello! How can I help you today?")
  tone                         String   @default("friendly")
  language                     String   @default("auto")
  aiProvider                   String   @default("openai")
  aiModel                      String   @default("gpt-4o-mini")
  aiApiKey                     String   @default("")
  maxTokens                    Int      @default(2048)
  temperature                  Float    @default(0.7)
  monthlyTokenBudget           Int      @default(1000000)
  tokenBudgetWarningPercent    Int      @default(80)
  elevenLabsKey                String   @default("")
  elevenLabsVoice              String   @default("")
  twilioSid                    String   @default("")
  twilioToken                  String   @default("")
  twilioPhone                  String   @default("")
  smtpHost                     String   @default("")
  smtpPort                     Int      @default(587)
  smtpUser                     String   @default("")
  smtpPass                     String   @default("")
  smtpFrom                     String   @default("")
  imapHost                     String   @default("")
  imapPort                     Int      @default(993)
  imapUser                     String   @default("")
  imapPass                     String   @default("")
  whatsappMode                 String   @default("web")
  whatsappApiKey               String   @default("")
  whatsappPhone                String   @default("")
  telegramBotToken             String   @default("")
  workflowApprovalStaleMinutes Int      @default(30)
  ticketCloseAutoReplyEnabled  Boolean  @default(true)
  ticketCloseRequireApproval   Boolean  @default(false)
  ticketCloseReplyTemplate     String   @default("Your ticket \"{{ticketTitle}}\" has been {{ticketStatus}}.\n\n{{resolution}}\n\nIf you need more help, reply here and our support team will follow up.")
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

// ==================== AUTH ====================

model Admin {
  id           String   @id @default(uuid())
  companyId    String
  // Globally unique (not per-company) - this is what makes login resolution
  // work without subdomain routing: the company is looked up from whichever
  // company this username belongs to.
  username     String   @unique
  email        String   @unique
  password     String
  name         String   @default("Admin")
  role         String   @default("admin")
  // Bumped whenever the password changes; embedded in issued JWTs so a
  // password change invalidates every previously issued session at once.
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// ==================== KNOWLEDGE BASE ====================

model Category {
  id          String                @id @default(uuid())
  companyId   String
  name        String
  description String                @default("")
  icon        String                @default("folder")
  color       String                @default("#F97316")
  sortOrder   Int                   @default(0)
  entries     KnowledgeEntry[]
  agentScopes AgentKnowledgeScope[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([companyId])
}

model KnowledgeEntry {
  id          String                @id @default(uuid())
  companyId   String
  categoryId  String
  category    Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title       String
  content     String
  priority    Int                   @default(0)
  isActive    Boolean               @default(true)
  version     Int                   @default(1)
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  chunks      KnowledgeChunk[]
  agentScopes AgentKnowledgeScope[]

  @@index([companyId])
  @@index([categoryId])
}

model KnowledgeDocument {
  id            String                  @id @default(uuid())
  companyId     String
  categoryId    String?
  title         String
  sourceType    String                  @default("upload")
  fileName      String                  @default("")
  mimeType      String                  @default("")
  sourceUrl     String                  @default("")
  storageBucket String                  @default("")
  storageKey    String                  @default("")
  storageUrl    String                  @default("")
  fileSize      Int                     @default(0)
  status        String                  @default("queued")
  extractedText String                  @default("")
  tableData     Json                    @default("[]")
  contentHash   String                  @default("")
  version       Int                     @default(1)
  tokenEstimate Int                     @default(0)
  metadata      Json                    @default("{}")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  runs          KnowledgeIngestionRun[]
  chunks        KnowledgeChunk[]
  agentScopes   AgentKnowledgeScope[]

  @@index([companyId])
  @@index([categoryId])
  @@index([sourceType])
  @@index([status])
  @@index([storageKey])
  @@index([contentHash])
  @@index([createdAt])
}

model KnowledgeIngestionRun {
  id             String            @id @default(uuid())
  companyId      String
  documentId     String
  document       KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  status         String            @default("queued")
  stage          String            @default("queued")
  logs           Json              @default("[]")
  error          String            @default("")
  extractedChars Int               @default(0)
  chunkCount     Int               @default(0)
  tokenEstimate  Int               @default(0)
  startedAt      DateTime          @default(now())
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([companyId])
  @@index([documentId])
  @@index([status])
  @@index([stage])
  @@index([createdAt])
}

model KnowledgeChunk {
  id               String            @id @default(uuid())
  companyId        String
  documentId       String
  document         KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  knowledgeEntryId String?
  knowledgeEntry   KnowledgeEntry?   @relation(fields: [knowledgeEntryId], references: [id], onDelete: SetNull)
  content          String
  sourceTitle      String            @default("")
  sourceUrl        String            @default("")
  pageNumber       Int?
  sheetName        String            @default("")
  rowStart         Int?
  rowEnd           Int?
  sectionHeading   String            @default("")
  chunkIndex       Int               @default(0)
  tokenEstimate    Int               @default(0)
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([companyId])
  @@index([documentId])
  @@index([knowledgeEntryId])
  @@index([sourceUrl])
}

model WebsiteSource {
  id              String    @id @default(uuid())
  companyId       String
  categoryId      String?
  url             String
  mode            String    @default("single_url")
  includePatterns String    @default("")
  excludePatterns String    @default("")
  crawlDepth      Int       @default(1)
  schedule        String    @default("manual")
  lastStatus      String    @default("never_run")
  lastCrawledAt   DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([categoryId])
  @@index([url])
  @@index([lastStatus])
}

model TokenUsage {
  id               String   @id @default(uuid())
  companyId        String
  provider         String
  model            String
  feature          String
  operation        String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  embeddingTokens  Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  entityType       String   @default("")
  entityId         String   @default("")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())

  @@index([companyId])
  @@index([feature])
  @@index([operation])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ==================== TEAM ====================

model Department {
  id          String       @id @default(uuid())
  companyId   String
  name        String
  description String       @default("")
  email       String       @default("")
  members     TeamMember[]
  tickets     Ticket[]
  agents      Agent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([companyId])
}

// Roles referenced by TeamMember.rbacRole / Admin.role (plain strings, no FK -
// matches this app's existing loose-coupling convention for role fields).
// Per-company: each company gets its own independently-editable copies of
// the 4 built-in roles (viewer/agent/supervisor/admin), seeded at
// registration - not shared global templates, so one company editing
// "agent" can never change behavior for another company.
model Role {
  id          String           @id @default(uuid())
  companyId   String
  name        String
  label       String
  isBuiltIn   Boolean          @default(false)
  isUnscoped  Boolean          @default(false)
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model RolePermission {
  id         String   @id @default(uuid())
  companyId  String
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime @default(now())

  @@unique([roleId, permission])
  @@index([companyId])
  @@index([roleId])
}

model TeamMember {
  id           String     @id @default(uuid())
  companyId    String
  name         String
  email        String
  phone        String     @default("")
  role         String     @default("member")
  expertise    String     @default("")
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  isAvailable  Boolean    @default(true)
  // Login credentials (null until an admin issues them). Globally unique
  // (not per-company) - same login-resolution reasoning as Admin.username.
  username     String?    @unique
  password     String?
  rbacRole     String     @default("viewer")
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  // Bumped whenever credentials are (re)issued; embedded in issued JWTs so
  // a password reset invalidates every previously issued session at once.
  tokenVersion Int        @default(0)
  tickets      Ticket[]
  moduleAssignments     ModuleAssignment[]
  assignedConversations Conversation[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([companyId])
  @@index([departmentId])
}

model ReporterChatThread {
  id        String                @id @default(uuid())
  companyId String
  userId    String
  userType  String                @default("member") // owner | member
  title     String                @default("Reporter Agent")
  messages  ReporterChatMessage[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([companyId])
  @@index([userId])
}

model ReporterChatMessage {
  id        String             @id @default(uuid())
  companyId String
  threadId  String
  thread    ReporterChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String // user | reporter
  content   String
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())

  @@index([companyId])
  @@index([threadId])
}

model ModuleAssignment {
  id           String     @id @default(uuid())
  companyId    String
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  moduleSlug   String
  access       String     @default("read") // read | write
  assignedBy   String     @default("")
  createdAt    DateTime   @default(now())

  @@unique([teamMemberId, moduleSlug])
  @@index([companyId])
  @@index([teamMemberId])
  @@index([moduleSlug])
}

// ==================== CONVERSATIONS ====================

model Conversation {
  id               String            @id @default(uuid())
  companyId        String
  channel          String
  customerName     String            @default("Unknown")
  customerContact  String            @default("")
  customerId       String?
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  agentId          String?
  agent            Agent?            @relation(fields: [agentId], references: [id], onDelete: SetNull)
  channelAccountId String?
  channelAccount   ChannelAccount?   @relation(fields: [channelAccountId], references: [id], onDelete: SetNull)
  assignedToId     String?
  assignedTo       TeamMember?       @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  status           String            @default("active")
  satisfaction     Int?
  summary          String            @default("")
  metadata         Json              @default("{}")
  messages         Message[]
  tickets          Ticket[]
  tags             ConversationTag[]
  notes            InternalNote[]
  workflowRuns     WorkflowRun[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([companyId])
  @@index([channel])
  @@index([status])
  @@index([customerContact])
  @@index([channel, status])
  @@index([createdAt])
  // The conversation list's default (and only) sort is updatedAt desc -
  // without this, every list page load does a full sort with no index.
  @@index([updatedAt])
  @@index([customerId])
  @@index([agentId])
  @@index([channelAccountId])
  @@index([assignedToId])
}

model Message {
  id             String       @id @default(uuid())
  companyId      String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  mediaType      String?
  mediaUrl       String?
  toolCalls      Json?
  createdAt      DateTime     @default(now())

  @@index([companyId])
  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// ==================== TICKETS ====================

model Ticket {
  id             String        @id @default(uuid())
  companyId      String
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     TeamMember?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  title          String
  description    String
  status         String        @default("open")
  priority       String        @default("medium")
  resolution     String        @default("")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([departmentId])
  @@index([assignedToId])
}

// ==================== TAGS ====================

model Tag {
  id            String            @id @default(uuid())
  companyId     String
  name          String
  color         String            @default("#F97316")
  conversations ConversationTag[]
  createdAt     DateTime          @default(now())

  @@unique([companyId, name])
  @@index([companyId])
}

model ConversationTag {
  id             String       @id @default(uuid())
  companyId      String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tagId          String
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tagId])
  @@index([companyId])
}

// ==================== CALL LOGS ====================

model CallLog {
  id        String   @id @default(uuid())
  companyId String
  callSid   String   @unique
  from      String
  to        String
  duration  Int      @default(0)
  status    String   @default("initiated")
  recording String?
  summary   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ==================== CHANNELS ====================

model Channel {
  id        String   @id @default(uuid())
  companyId String
  type      String
  isActive  Boolean  @default(false)
  config    Json     @default("{}")
  status    String   @default("disconnected")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, type])
  @@index([companyId])
}

model Agent {
  id                     String                @id @default(uuid())
  companyId              String
  name                   String
  description            String                @default("")
  status                 String                @default("active")
  tone                   String                @default("friendly")
  language               String                @default("auto")
  systemPrompt           String                @default("")
  fallbackMode           String                @default("ai_reply")
  automationMode         String                @default("workflow_first")
  requireApproval        Boolean               @default(false)
  useGlobalKnowledge     Boolean               @default(true)
  escalationDepartmentId String?
  escalationDepartment   Department?           @relation(fields: [escalationDepartmentId], references: [id], onDelete: SetNull)
  metadata               Json                  @default("{}")
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  channelAccounts        AgentChannelAccount[]
  defaultForAccounts     ChannelAccount[]      @relation("DefaultAgentChannelAccounts")
  knowledgeScopes        AgentKnowledgeScope[]
  workflows              AgentWorkflow[]
  tools                  AgentTool[]
  conversations          Conversation[]

  @@index([companyId])
  @@index([status])
  @@index([escalationDepartmentId])
}

model ChannelAccount {
  id             String                @id @default(uuid())
  companyId      String
  channel        String
  name           String
  identifier     String
  status         String                @default("disconnected")
  isActive       Boolean               @default(true)
  credentials    Json                  @default("{}")
  settings       Json                  @default("{}")
  automationMode String                @default("workflow_first")
  defaultAgentId String?
  defaultAgent   Agent?                @relation("DefaultAgentChannelAccounts", fields: [defaultAgentId], references: [id], onDelete: SetNull)
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  agents         AgentChannelAccount[]
  conversations  Conversation[]

  @@unique([channel, identifier])
  @@index([companyId])
  @@index([channel])
  @@index([identifier])
  @@index([defaultAgentId])
  @@index([status])
}

model AgentChannelAccount {
  id               String         @id @default(uuid())
  companyId        String
  agentId          String
  agent            Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channelAccountId String
  channelAccount   ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  isPrimary        Boolean        @default(false)
  priority         Int            @default(100)
  routingRules     Json           @default("{}")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([agentId, channelAccountId])
  @@index([companyId])
  @@index([agentId])
  @@index([channelAccountId])
  @@index([priority])
}

model AgentKnowledgeScope {
  id         String             @id @default(uuid())
  companyId  String
  agentId    String
  agent      Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category?          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  entryId    String?
  entry      KnowledgeEntry?    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  documentId String?
  document   KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  scopeType  String             @default("include")
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([companyId])
  @@index([agentId])
  @@index([categoryId])
  @@index([entryId])
  @@index([documentId])
}

model AgentWorkflow {
  id        String   @id @default(uuid())
  companyId String
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  flowId    String
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  priority  Int      @default(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, flowId])
  @@index([companyId])
  @@index([agentId])
  @@index([flowId])
  @@index([priority])
}

model AgentTool {
  id               String   @id @default(uuid())
  companyId        String
  agentId          String
  agent            Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolType         String
  toolName         String
  isEnabled        Boolean  @default(true)
  requiresApproval Boolean  @default(false)
  config           Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([agentId, toolType, toolName])
  @@index([companyId])
  @@index([agentId])
  @@index([toolType])
}

// ==================== SCHEDULES ====================

model Schedule {
  id           String @id @default(uuid())
  companyId    String
  teamMemberId String
  dayOfWeek    Int
  startTime    String
  endTime      String

  @@index([companyId])
  @@index([teamMemberId])
  @@index([dayOfWeek])
}

// ==================== WEBHOOKS ====================

model Webhook {
  id          String            @id @default(uuid())
  companyId   String
  name        String
  description String            @default("")
  url         String
  method      String            @default("POST")
  headers     Json              @default("{}")
  isActive    Boolean           @default(true)
  triggerOn   String
  deliveries  WebhookDelivery[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([companyId])
}

model WebhookDelivery {
  id          String    @id @default(uuid())
  companyId   String
  webhookId   String
  webhook     Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event       String
  payload     Json
  status      String    @default("pending") // pending, delivered, failed
  statusCode  Int?
  attempts    Int       @default(0)
  lastError   String?
  nextRetryAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([webhookId])
  @@index([status, nextRetryAt])
}

// ==================== ACTIVITY LOG ====================

model ActivityLog {
  id          String   @id @default(uuid())
  companyId   String
  action      String // conversation.created, ticket.assigned, settings.updated, etc.
  entity      String // conversation, ticket, settings, knowledge, team
  entityId    String?
  description String
  userId      String?
  userName    String   @default("System")
  metadata    Json     @default("{}")
  requestId   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([entity])
  @@index([createdAt])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id             String    @id @default(uuid())
  companyId      String
  type           String
  title          String
  message        String
  priority       String    @default("normal")
  href           String    @default("")
  conversationId String?
  metadata       Json      @default("{}")
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([companyId])
  @@index([readAt])
  @@index([createdAt])
  @@index([conversationId])
  @@index([type])
}

// ==================== SLA RULES ====================

model SLARule {
  id                String   @id @default(uuid())
  companyId         String
  name              String
  description       String   @default("")
  channel           String   @default("all") // all, whatsapp, email, phone
  priority          String   @default("all") // all, low, medium, high, urgent
  firstResponseMins Int      @default(30)
  resolutionMins    Int      @default(480)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companyId])
}

// ==================== CANNED RESPONSES ====================

model CannedResponse {
  id         String   @id @default(uuid())
  companyId  String
  title      String
  content    String
  category   String   @default("General")
  shortcut   String   @default("") // e.g., /greeting, /refund
  isActive   Boolean  @default(true)
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}

// ==================== CUSTOMERS ====================

model Customer {
  id            String         @id @default(uuid())
  companyId     String
  name          String
  email         String         @default("")
  phone         String         @default("")
  whatsapp      String         @default("")
  tags          String         @default("") // comma-separated
  isBlocked     Boolean        @default(false)
  notes         CustomerNote[]
  conversations Conversation[]
  metadata      Json           @default("{}")
  firstContact  DateTime       @default(now())
  lastContact   DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
  @@index([email])
  @@index([phone])
  @@index([whatsapp])
  @@index([lastContact])
}

model CustomerNote {
  id         String   @id @default(uuid())
  companyId  String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  authorName String   @default("Admin")
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([customerId])
}

// ==================== AUTOMATION RULES ====================

model AutomationRule {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  description  String   @default("")
  type         String // auto_route, auto_tag, auto_reply, keyword_alert
  isActive     Boolean  @default(true)
  conditions   Json     @default("[]") // [{field, operator, value}]
  actions      Json     @default("[]") // [{type, target, value}]
  priority     Int      @default(0)
  triggerCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// ==================== BUSINESS HOURS ====================

model BusinessHours {
  companyId      String  @id
  enabled        Boolean @default(false)
  timezone       String  @default("UTC")
  monday         String  @default("09:00-18:00") // empty = closed
  tuesday        String  @default("09:00-18:00")
  wednesday      String  @default("09:00-18:00")
  thursday       String  @default("09:00-18:00")
  friday         String  @default("09:00-18:00")
  saturday       String  @default("")
  sunday         String  @default("")
  offlineMessage String  @default("We are currently offline. We will get back to you during business hours.")
}

// ==================== API KEYS ====================

model ApiKey {
  id        String    @id @default(uuid())
  companyId String
  name      String
  key       String    @unique
  isActive  Boolean   @default(true)
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([companyId])
  @@index([key])
}

// ==================== INTERNAL NOTES ====================

model InternalNote {
  id             String       @id @default(uuid())
  companyId      String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content        String
  authorName     String       @default("Admin")
  createdAt      DateTime     @default(now())

  @@index([companyId])
  @@index([conversationId])
}

// ==================== CAMPAIGNS ====================

model Campaign {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String    @default("")
  channel     String    @default("email")
  message     String
  subject     String    @default("")
  segments    Json      @default("[]")
  status      String    @default("draft") // draft, scheduled, running, completed, paused
  scheduledAt DateTime?
  sentCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
}

// ==================== FLOWS ====================

model Flow {
  id             String          @id @default(uuid())
  companyId      String
  name           String
  description    String          @default("")
  startNodeId    String          @default("")
  nodes          Json            @default("[]")
  edges          Json            @default("[]")
  isActive       Boolean         @default(false)
  // Lower runs first when several active flows match the same trigger
  // (matches AgentWorkflow.priority's convention). New flows default to
  // last-in-evaluation-order (see the create route), not 0, so they don't
  // silently jump ahead of existing flows.
  priority       Int             @default(0)
  triggerCount   Int             @default(0)
  runs           WorkflowRun[]
  agentWorkflows AgentWorkflow[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId])
}

model WorkflowRun {
  id             String            @id @default(uuid())
  companyId      String
  flowId         String?
  flow           Flow?             @relation(fields: [flowId], references: [id], onDelete: SetNull)
  flowName       String            @default("")
  conversationId String?
  conversation   Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  triggerEvent   String
  channel        String
  status         String            @default("started")
  reason         String            @default("")
  messagePreview String            @default("")
  metadata       Json              @default("{}")
  steps          WorkflowRunStep[]
  startedAt      DateTime          @default(now())
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([companyId])
  @@index([flowId])
  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
}

model WorkflowRunStep {
  id         String      @id @default(uuid())
  companyId  String
  runId      String
  run        WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId     String      @default("")
  nodeLabel  String      @default("")
  nodeType   String      @default("")
  actionType String      @default("")
  status     String
  message    String      @default("")
  metadata   Json        @default("{}")
  startedAt  DateTime    @default(now())
  endedAt    DateTime?
  createdAt  DateTime    @default(now())

  @@index([companyId])
  @@index([runId])
  @@index([status])
  @@index([nodeId])
}

model WorkflowJob {
  id             String    @id @default(uuid())
  companyId      String
  flowId         String
  flowName       String    @default("")
  conversationId String
  triggerEvent   String
  channel        String
  customerId     String?
  message        String    @default("")
  nextNodeId     String    @default("")
  status         String    @default("pending")
  runId          String?
  dueAt          DateTime
  lockedAt       DateTime?
  completedAt    DateTime?
  lastError      String    @default("")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId])
  @@index([status, dueAt])
  @@index([flowId])
  @@index([conversationId])
}

// ==================== BUSINESS MODULES ====================

model BusinessModule {
  id          String         @id @default(uuid())
  companyId   String
  slug        String
  name        String
  category    String
  description String         @default("")
  version     String         @default("0.1.0")
  isInstalled Boolean        @default(false)
  isEnabled   Boolean        @default(false)
  config      Json           @default("{}")
  metadata    Json           @default("{}")
  installedAt DateTime?
  installedBy String?
  disabledAt  DateTime?
  records     ModuleRecord[]
  signals     ModuleSignal[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([category])
  @@index([isInstalled, isEnabled])
}

model ModuleRecord {
  id             String          @id @default(uuid())
  companyId      String
  moduleId       String
  module         BusinessModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  recordType     String
  title          String
  status         String          @default("open")
  priority       String          @default("normal")
  sourceChannel  String          @default("")
  sourceMessage  String          @default("")
  sourceMessageId String?
  conversationId String?
  customerId     String?
  data           Json            @default("{}")
  reporterState  String          @default("normal")
  reporterNotes  String          @default("")
  events         ModuleRecordEvent[]
  signals        ModuleSignal[]
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId])
  @@index([moduleId])
  @@index([recordType])
  @@index([status])
  @@index([priority])
  @@index([reporterState])
  @@index([conversationId])
  @@index([customerId])
  @@index([sourceMessageId])
  // Every module-records query filters by moduleId (always present) and
  // sorts updatedAt desc - a plain moduleId index still needs a full sort.
  @@index([moduleId, updatedAt])
}

model ModuleRecordEvent {
  id             String       @id @default(uuid())
  companyId      String
  moduleRecordId String
  moduleRecord   ModuleRecord @relation(fields: [moduleRecordId], references: [id], onDelete: Cascade)
  action         String
  description    String
  metadata       Json         @default("{}")
  createdBy      String?
  createdAt      DateTime     @default(now())

  @@index([companyId])
  @@index([moduleRecordId])
  @@index([action])
  @@index([createdAt])
}

model ModuleSignal {
  id             String          @id @default(uuid())
  companyId      String
  moduleId       String
  module         BusinessModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleRecordId String?
  moduleRecord   ModuleRecord?   @relation(fields: [moduleRecordId], references: [id], onDelete: SetNull)
  signalType     String
  severity       String          @default("medium")
  title          String
  description    String          @default("")
  status         String          @default("open")
  metadata       Json            @default("{}")
  createdBy      String?
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId])
  @@index([moduleId])
  @@index([moduleRecordId])
  @@index([signalType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// ==================== ERP CONNECTORS ====================
// Structural framework for SAP / Oracle Fusion / Microsoft 365 / Dynamics
// 365 Business Central / Odoo integrations. Credential storage + a manual
// test-connection ping only in this pass - no live data sync yet.

model Connector {
  id             String    @id @default(uuid())
  companyId      String
  provider       String // "sap" | "oracle" | "microsoft365" | "dynamics_bc" | "odoo"
  name           String
  authType       String // "oauth2" | "api_key" | "basic_auth"
  status         String    @default("disconnected") // disconnected | connecting | connected | error
  isActive       Boolean   @default(true)
  config         Json      @default("{}") // non-secret: tenantId, instanceUrl, clientId, environment, database...
  credentials    Json      @default("{}") // secret: apiKey, username/password, clientSecret, accessToken, refreshToken, tokenExpiresAt - encrypted at rest
  lastTestedAt   DateTime?
  lastTestResult Json      @default("{}")
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([companyId, provider, name])
  @@index([companyId])
  @@index([provider])
  @@index([status])
}

model ConnectorOAuthState {
  id                  String   @id @default(uuid())
  companyId           String
  state               String   @unique
  provider            String
  connectorId         String? // set when re-authorizing an existing connector
  pendingName         String?
  pendingConfig       Json     @default("{}")
  pendingClientSecret String? // encrypted flat field
  codeVerifier        String? // PKCE
  createdBy           String
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  @@index([companyId])
  @@index([expiresAt])
}

// ==================== BILLING ====================
// One BillingAccount per Company (PK is companyId itself, no more "default"
// singleton) - each company's subscription gates its own module quota
// independently.

model BillingAccount {
  companyId            String    @id
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String? // "free" | "starter" | "growth" | "unlimited"
  billingCycle         String? // "monthly" | "annual"
  status               String    @default("none") // none | trialing | active | past_due | canceled | incomplete
  currentPeriodEnd     DateTime?
  gracePeriodEndsAt    DateTime?
  moduleQuotaExceeded  Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}
