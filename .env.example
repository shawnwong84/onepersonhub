DATABASE_URL="postgresql://postgres:postgres@localhost:5432/owly?schema=public"
JWT_SECRET="change-me"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis is used for distributed cache, embedding/query cache, and rate-limit state.
REDIS_URL="redis://localhost:6379"

# MinIO/S3-compatible object storage for original RAG source files.
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="owly-rag"
S3_FORCE_PATH_STYLE="true"

# Optional website ingestion provider.
FIRECRAWL_API_KEY=""
