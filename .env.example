DATABASE_URL="postgresql://postgres:postgres@localhost:5432/owly?schema=public"
JWT_SECRET="change-me"
# Local dev: "http://localhost:3000". Production (docker-compose.yml's "app"
# service overrides this to the real domain, but keep it in sync here too):
# "https://paperhuman.im"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Contact email Caddy registers with Let's Encrypt for the paperhuman.im
# certificate (account/expiry notices only, not used by the app itself).
ACME_EMAIL="admin@paperhuman.im"

# Encrypts channel/AI provider secrets at rest (Settings, ChannelAccount.credentials,
# Channel.config). Required in production. Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=""

# When "true", POST /api/webhooks/inbound rejects API-key requests that don't
# include a valid X-Signature-256 header (HMAC-SHA256 of the raw body, signed
# with the caller's own API key). Optional/advisory when unset.
WEBHOOK_INBOUND_REQUIRE_SIGNATURE=""

# How many days an issued login session (JWT cookie) stays valid. Defaults to 7
# if unset or invalid.
SESSION_LIFETIME_DAYS="7"

# Redis is used for distributed cache, embedding/query cache, and rate-limit state.
REDIS_URL="redis://localhost:6379"

# MinIO/S3-compatible object storage for original RAG source files.
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="owly-rag"
S3_FORCE_PATH_STYLE="true"

# Optional website ingestion provider.
FIRECRAWL_API_KEY=""

# Resend (resend.com) sends system/transactional email (e.g. the
# registration welcome email) as Paperhuman itself. Separate from each
# company's own SMTP credentials used for the customer-facing email channel.
RESEND_API_KEY=""
EMAIL_FROM="Paperhuman <hello@paperhuman.im>"

# Stripe subscription billing (gates which business modules this deployment
# can enable - see src/lib/billing/plans.ts). Test-mode keys are fine for dev.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs created in the Stripe Dashboard for each plan/cycle combination.
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_GROWTH_MONTHLY=""
STRIPE_PRICE_GROWTH_ANNUAL=""
STRIPE_PRICE_UNLIMITED_MONTHLY=""
STRIPE_PRICE_UNLIMITED_ANNUAL=""

# E-commerce connector app credentials (Shopee/Lazada/TikTok Shop Open
# Platform partner apps). These are shared across every company on this
# deployment - one partner app per platform, not per-tenant - so a user
# connecting a shop never enters them; they just click Connect and go
# straight to that platform's OAuth consent screen.
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
LAZADA_APP_KEY=""
LAZADA_APP_SECRET=""
TIKTOK_SHOP_APP_KEY=""
TIKTOK_SHOP_APP_SECRET=""
